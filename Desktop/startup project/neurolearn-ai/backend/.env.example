# Application
APP_NAME=NeuroLearn AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=neurolearn

# Redis
REDIS_URL=redis://localhost:6379/0

# Firebase
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_CLIENT_ID=your_client_id
FIREBASE_AUTH_URI=https://auth.firebase.com
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your_client_id

# JWT
JWT_SECRET_KEY=your_jwt_secret_key_change_this_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# AI/LLM Configuration
LLM_PROVIDER=ollama
LLM_MODEL=llama3
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=your_openai_api_key_if_using_openai

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=neurolearn

# Document Processing
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=pdf,docx,pptx,txt,md
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
OCR_ENABLED=True
TESSERACT_CMD=tesseract

# File Storage
UPLOAD_DIRECTORY=./uploads
PROCESSED_DIRECTORY=./processed

# Computer Vision
ENABLE_GPU=True
CNN_MODEL=efficientnet_b0
OCR_ENGINE=paddleocr
IMAGE_MAX_SIZE=10485760
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,bmp,tiff,webp
OCR_CONFIDENCE_THRESHOLD=0.5
CNN_CONFIDENCE_THRESHOLD=0.7

# Learning Intelligence Engine
LSTM_MODEL_ENABLED=True
LSTM_SEQUENCE_LENGTH=30
LSTM_PREDICTION_HORIZON=7
RETRAIN_INTERVAL_DAYS=7
MIN_TRAINING_SAMPLES=100

# Agentic AI
AGENT_MEMORY_ENCRYPTION=True
AGENT_MAX_MEMORY_TOKENS=10000
AGENT_TIMEOUT_SECONDS=30
ENABLE_AGENT_ORCHESTRATION=True

# Recommendations
RECOMMENDATION_ENGINE_ENABLED=True
RECOMMENDATION_CACHE_TTL=3600
MIN_RECOMMENDATION_SCORE=0.5
